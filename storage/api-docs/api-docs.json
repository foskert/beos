{
    "openapi": "3.0.0",
    "info": {
        "title": "BEOS API",
        "description": "Documentación oficial de la API BEOS",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor Local"
        }
    ],
    "paths": {
        "/api/v1/audits/products/{id}": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Consultar historial de auditoría de un producto",
                "operationId": "c9c32b94b539c2b06cc1559da6e478a3",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto (incluye eliminados)",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Historial de cambios recuperado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Auditoría consultada."
                                        },
                                        "value": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/AuditResource"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Producto no encontrado"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/products/{id}": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Obtener detalles de un producto",
                "operationId": "bce75497973db64e5bbe555bba40a0c8",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto a consultar",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detalles del producto",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Producto consultado correctamente."
                                        },
                                        "value": {
                                            "$ref": "#/components/schemas/ProductResource"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Producto no encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "El producto solicitado no existe."
                                        },
                                        "value": {
                                            "type": "null"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno del servidor"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Productos"
                ],
                "summary": "Actualizar un producto existente",
                "operationId": "b54fe4f829770857fc87ba29ddda0017",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto a actualizar",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "maxLength": 255,
                                        "example": "Producto Editado"
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 199.99
                                    },
                                    "tax_cost": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 20
                                    },
                                    "currency_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "manufacturing_cost": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 100
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Nueva descripción",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Producto actualizado con éxito",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Producto actualizado correctamente."
                                        },
                                        "value": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Producto Editado"
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "example": "Nueva descripción"
                                                },
                                                "price": {
                                                    "type": "string",
                                                    "example": "199.99"
                                                },
                                                "currency": {
                                                    "properties": {
                                                        "name": {
                                                            "type": "string",
                                                            "example": "Dólar"
                                                        },
                                                        "symbol": {
                                                            "type": "string",
                                                            "example": "USD"
                                                        },
                                                        "exchange_rate": {
                                                            "type": "string",
                                                            "example": "1.00"
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "manufacturing_cost": {
                                                    "type": "string",
                                                    "example": "100.00"
                                                },
                                                "tax_cost": {
                                                    "type": "string",
                                                    "example": "20.00"
                                                },
                                                "created_at": {
                                                    "type": "string",
                                                    "example": "2024-03-20"
                                                },
                                                "updated_at": {
                                                    "type": "string",
                                                    "example": "2024-03-20"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Producto no encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "El producto no existe."
                                        },
                                        "value": {
                                            "type": "null"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Datos de validación inválidos"
                    },
                    "500": {
                        "description": "Error interno del servidor"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Productos"
                ],
                "summary": "Eliminar un producto",
                "operationId": "0330e353559737d2cd38ceb4ac12538c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto a eliminar",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Producto eliminado correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Producto eliminado con éxito."
                                        },
                                        "value": {
                                            "$ref": "#/components/schemas/ProductResource"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Producto no encontrado o ya eliminado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "No se encontró el producto para eliminar."
                                        },
                                        "value": {
                                            "type": "null"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno del servidor"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/products": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Listado paginado de productos con filtros",
                "operationId": "7c9c65dc74c69439386c99a2ced8d90b",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Buscar por nombre",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "currency_id",
                        "in": "query",
                        "description": "Filtrar por ID de moneda",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "paginate",
                        "in": "query",
                        "description": "Resultados por página",
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "description": "Campo de ordenación",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "id",
                                "name",
                                "price",
                                "created_at"
                            ]
                        }
                    },
                    {
                        "name": "order_by",
                        "in": "query",
                        "description": "Dirección",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "asc",
                                "desc"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Listado de productos recuperado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Productos listados con éxito."
                                        },
                                        "value": {
                                            "$ref": "#/components/schemas/ProductListResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error en el servidor"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Productos"
                ],
                "summary": "Crear un nuevo producto",
                "operationId": "728ebebe37c18429b6efc48655179ffa",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "price",
                                    "tax_cost",
                                    "currency_id",
                                    "manufacturing_cost"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "maxLength": 255,
                                        "example": "Producto Premium"
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "minimum": 0,
                                        "example": 150.5
                                    },
                                    "tax_cost": {
                                        "type": "number",
                                        "format": "float",
                                        "minimum": 0,
                                        "example": 15
                                    },
                                    "currency_id": {
                                        "description": "ID de la moneda existente",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "manufacturing_cost": {
                                        "type": "number",
                                        "format": "float",
                                        "minimum": 0,
                                        "example": 80
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Descripción detallada del producto",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Producto creado con éxito",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Producto guardado correctamente."
                                        },
                                        "value": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Producto Premium"
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "example": "Descripción..."
                                                },
                                                "price": {
                                                    "type": "string",
                                                    "example": "150.50"
                                                },
                                                "currency": {
                                                    "properties": {
                                                        "name": {
                                                            "type": "string",
                                                            "example": "Dólar"
                                                        },
                                                        "symbol": {
                                                            "type": "string",
                                                            "example": "USD"
                                                        },
                                                        "exchange_rate": {
                                                            "type": "string",
                                                            "example": "1.00"
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "manufacturing_cost": {
                                                    "type": "string",
                                                    "example": "80.00"
                                                },
                                                "tax_cost": {
                                                    "type": "string",
                                                    "example": "15.00"
                                                },
                                                "created_at": {
                                                    "type": "string",
                                                    "example": "2024-03-20"
                                                },
                                                "updated_at": {
                                                    "type": "string",
                                                    "example": "2024-03-20"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Error de validación (Ej. Nombre duplicado o campos faltantes)"
                    },
                    "500": {
                        "description": "Error interno del servidor",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Hubo un error al procesar la solicitud."
                                        },
                                        "value": {
                                            "type": "string",
                                            "example": "Mensaje de la excepción..."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/products/{id}/prices": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Listado de precios por moneda de un producto",
                "operationId": "daae7359dab47accb889c9a75413d34c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Precios recuperados",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Precios consultados con éxito."
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/PriceIndexResponse"
                                            }
                                        },
                                        "links": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "$ref": "#/components/schemas/PaginationMeta"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Productos"
                ],
                "summary": "Asignar un nuevo precio a un producto",
                "operationId": "65efd9ec639e4c450c1b95f02d51bbe6",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto al que se le añade el precio",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "price",
                                    "product_id",
                                    "currency_id"
                                ],
                                "properties": {
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 1250
                                    },
                                    "product_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "currency_id": {
                                        "type": "integer",
                                        "example": 2
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Precio creado correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Precio asignado con éxito."
                                        },
                                        "value": {
                                            "$ref": "#/components/schemas/PriceIndexResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Error de validación"
                    },
                    "500": {
                        "description": "Error interno del servidor"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/login": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Inicio de sesión de usuario",
                "description": "Retorna el token Bearer para autenticación",
                "operationId": "0a3bf87b83ee15b9e8c698e7ae8f2099",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@admin.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "1234567890"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Login exitoso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Autenticación exitosa"
                                        },
                                        "access_token": {
                                            "type": "string",
                                            "example": "1|3v9M..."
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "user": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Admin"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "admin@beos.com"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Credenciales inválidas"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ProductResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Producto A"
                    },
                    "price": {
                        "type": "string",
                        "example": "100.00"
                    }
                },
                "type": "object"
            },
            "PriceIndexResponse": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Producto X"
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "price": {
                        "type": "string",
                        "example": "120.50"
                    },
                    "currency": {
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "symbol": {
                                "type": "string"
                            },
                            "exchange_rate": {
                                "type": "string"
                            }
                        },
                        "type": "object",
                        "nullable": true
                    },
                    "prices": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "price": {
                                    "type": "string"
                                },
                                "currency": {
                                    "type": "object",
                                    "nullable": true
                                }
                            },
                            "type": "object"
                        }
                    },
                    "manufacturing_cost": {
                        "type": "string"
                    },
                    "tax_cost": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string"
                    },
                    "updated_at": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "ProductListResponse": {
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ProductResource"
                        }
                    },
                    "links": {
                        "type": "object"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/PaginationMeta"
                    }
                },
                "type": "object"
            },
            "PaginationMeta": {
                "properties": {
                    "current_page": {
                        "type": "integer"
                    },
                    "last_page": {
                        "type": "integer"
                    },
                    "total": {
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "AuditResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "Ingresa solo el token (ej: 4|lGMHH...) y Swagger añadirá \"Bearer \" por ti."
            }
        }
    },
    "tags": [
        {
            "name": "Productos",
            "description": "Productos"
        },
        {
            "name": "Autenticación",
            "description": "Autenticación"
        }
    ]
}